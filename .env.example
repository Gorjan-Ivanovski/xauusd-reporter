# =============================================
# XAU/USD Daily Reporter - Configuration
# =============================================

# --- OPTION 1: SendGrid (Recommended - Simplest) ---
# 1. Sign up free at: https://signup.sendgrid.com
# 2. Create API key at: https://app.sendgrid.com/settings/api_keys
# 3. Paste the key below (starts with SG.)
SENDGRID_API_KEY=

# --- OPTION 2: Gmail SMTP (Alternative) ---
# For Gmail: Use an App Password - NOT your regular password
# Generate at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# --- RECIPIENT ---
RECIPIENT_EMAIL=Gorjan.ivanovski@gmail.com

# --- SCHEDULING ---
REPORT_TIME=07:00
TIMEZONE=Europe/Skopje

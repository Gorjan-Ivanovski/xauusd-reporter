# =============================================
# XAU/USD Daily Reporter - Configuration
# =============================================

# --- TWELVEDATA API KEY (Primary data source) ---
# 1. Sign up free at: https://twelvedata.com/pricing
# 2. Copy your API key from the dashboard
# 3. Paste the key below
TWELVEDATA_API_KEY=

# --- SENDGRID (Optional - for email delivery) ---
# Sign up free at: https://signup.sendgrid.com
# Create API key at: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=

# --- RECIPIENT ---
RECIPIENT_EMAIL=Gorjan.ivanovski@gmail.com

# --- SCHEDULING ---
# Report time in AEST (Australia/Sydney)
REPORT_TIME=07:00
TIMEZONE=Australia/Sydney
